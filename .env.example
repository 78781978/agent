# Bezpieczny szablon zmiennych srodowiskowych.
# Skopiuj ten plik jako .env.local i dopiero tam wklej prawdziwe klucze.
# Plik .env.local jest ignorowany przez Git i nie powinien trafic na GitHub.

# Google / Gemini API
# Wystarczy uzupelnic jeden z ponizszych kluczy, jezeli projekt korzysta z Google AI.
GOOGLE_API_KEY=tu_wklej_klucz_google
GOOGLE_GENERATIVE_AI_API_KEY=tu_wklej_klucz_google
GEMINI_API_KEY=tu_wklej_klucz_google

# Narzedzie Google Search Grounding
ENABLE_SEARCH_GROUNDING=false

# Supabase / pgvector / baza wiedzy
NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_wklej_publiczny_anon_key

# Opcjonalnie dla backendowych operacji administracyjnych w Supabase.
# Nie uzywaj tej zmiennej po stronie przegladarki.
SUPABASE_SERVICE_ROLE_KEY=tu_wklej_service_role_key_tylko_na_serwerze
